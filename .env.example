# --- Vision (label OCR) backend ---
#
# Production: set EXPO_PUBLIC_API_BASE_URL to the URL of the Cloudflare
# Worker in /proxy. The Worker holds the Anthropic key server-side and
# enforces the daily free-tier quota.
EXPO_PUBLIC_API_BASE_URL=

# Dev fallback: if EXPO_PUBLIC_API_BASE_URL is empty, the app calls
# Anthropic directly using this key. NEVER ship a build with this set —
# EXPO_PUBLIC_ vars are extractable from the JS bundle and your key will
# be drained.
EXPO_PUBLIC_ANTHROPIC_API_KEY=
